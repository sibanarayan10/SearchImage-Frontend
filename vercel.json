{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.pixhunt.xyz/:path*"
    },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.avif",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/avif"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
